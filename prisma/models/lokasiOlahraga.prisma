model LokasiOlahraga {
  id          Int      @id @default(autoincrement())
  
  name        String
  address     String?
  latitude    Float?
  longitude   Float?
  
  user_id     Int
  account     Account  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at  DateTime? @default(now())
  updated_at  DateTime? @updatedAt

  @@map("lokasi_olahraga")
}
